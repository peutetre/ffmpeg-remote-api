# Port du serveur
PORT=3000

# Configuration Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Configuration JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# Taille maximale des uploads (en Mo)
MAX_UPLOAD_SIZE_MB=5000

# Nombre maximum de jobs en parallèle
MAX_CONCURRENT_JOBS=4

# Timeout par défaut pour les jobs (en heures)
FFPROG_TIMEOUT_HOURS=2

# Durée de vie des fichiers temporaires (en heures)
TEMP_FILE_TTL_HOURS=24

# Chemins des dossiers
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info

# Origin autorisée pour Socket.io
SOCKET_IO_ORIGIN=*
