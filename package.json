{
  "name": "ffmpeg-remote-api",
  "version": "1.0.1",
  "description": "API pour exécuter des jobs ffmpeg à distance",
  "main": "src/server.js",
  "bin": {
    "ffmpeg-api": "./cli.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/ffmpegWorker.js",
    "cli": "node cli.js",
    "test-client": "node test/client.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest -c jest.unit.config.js",
    "test:integration": "jest -c jest.integration.config.js",
    "test:watch": "jest -c jest.unit.config.js --watch",
    "test:coverage": "jest -c jest.unit.config.js --coverage"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "5.9.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "ora": "^9.3.0",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "form-data": "^4.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
